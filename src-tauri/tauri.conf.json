{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BIG Hat Entertainment",
  "version": "32.0.0-alpha.11",
  "identifier": "live.bighat.entertainment",
  "build": {
    "frontendDist": "../frontend/build",
    "devUrl": "http://localhost:3000"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "BIG Hat Entertainment",
        "url": "splash.html",
        "width": 1400,
        "height": 900,
        "minWidth": 1100,
        "minHeight": 720,
        "center": true,
        "resizable": true,
        "maximized": false,
        "fullscreen": false,
        "decorations": false,
        "transparent": false,
        "alwaysOnTop": false,
        "visible": true,
        "backgroundColor": "#000e2a",
        "theme": "Dark",
        "shadow": true,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null,
      "freezePrototype": false
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi", "dmg", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "resources": {
      "../packaging/bighat.ico": "bighat.ico"
    },
    "externalBin": [
      "binaries/bighat-backend"
    ],
    "copyright": "© BH Entertainment",
    "category": "Productivity",
    "shortDescription": "BIG Hat Entertainment — Host Command Center",
    "longDescription": "Trivia, Bingo, and Scoreboard tools for live event hosts. Fully offline-capable with optional cloud sync.",
    "publisher": "BH Entertainment",
    "homepage": "https://bighat.live",
    "fileAssociations": [
      {
        "ext": ["bighat"],
        "name": "BIG Hat round file",
        "description": "Portable BIG Hat round / bingo / scoreboard archive",
        "role": "Editor",
        "mimeType": "application/x-bighat"
      }
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      },
      "nsis": {
        "displayLanguageSelector": false,
        "installerIcon": "icons/icon.ico",
        "installMode": "perMachine",
        "languages": ["English"],
        "installerHooks": "installer-hooks.nsh"
      },
      "wix": {
        "language": ["en-US"]
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15",
      "exceptionDomain": "",
      "signingIdentity": null,
      "providerShortName": null,
      "entitlements": null
    },
    "linux": {
      "deb": { "depends": [] }
    }
  },
  "plugins": {
    "shell": {
      "open": false
    }
  }
}
